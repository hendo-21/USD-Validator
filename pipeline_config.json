{
    "checks": {
        "default_prim": {
            "default_severity": "ERROR",
            "severity_by_path": {
                "**/shots/**": "WARNING"
            }
        },
        "references": {
            "default_severity": "ERROR",
            "severity_by_path": {}
        },
        "naming": {
            "default_severity": "WARNING",
            "severity_by_path": {
                "**/assets/**": "ERROR"
            },
            "conventions": {
                "file_pattern": "^\\w+_\\w+_\\w+_v\\d{3}\\.usda$",
                "prim_patterns": {
                    "mesh": "_GEO",
                    "skeleton": "_SKL",
                    "material": "_MAT",
                    "domelight": "_LGT"
                }
            }
        }
    }
}